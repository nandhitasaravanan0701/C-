#include <vector>
#include <algorithm>
#include <cstring>

using namespace std;

class Solution {
    int memo[100][100][100];

    int solve(vector<int>& boxes, int i, int j, int k) {
        if (i > j) return 0;
        if (memo[i][j][k] != 0) return memo[i][j][k];

        // Optimization: Combine all adjacent boxes of the same color as boxes[i]
        int i0 = i, k0 = k;
        while (i + 1 <= j && boxes[i + 1] == boxes[i]) {
            i++;
            k++;
        }

        // Option 1: Remove these k+1 boxes immediately
        int res = (k + 1) * (k + 1) + solve(boxes, i + 1, j, 0);

        // Option 2: Try to merge these boxes with another boxes[m] of the same color
        for (int m = i + 1; m <= j; m++) {
            if (boxes[m] == boxes[i]) {
                res = max(res, solve(boxes, i + 1, m - 1, 0) + solve(boxes, m, j, k + 1));
            }
        }

        return memo[i0][j][k0] = res;
    }

public:
    int removeBoxes(vector<int>& boxes) {
        memset(memo, 0, sizeof(memo));
        return solve(boxes, 0, boxes.size() - 1, 0);
    }
};
