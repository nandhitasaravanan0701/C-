#include <string>
#include <vector>
#include <unordered_map>

using namespace std;

class Solution {
public:
    int getMaxRepetitions(string s1, int n1, string s2, int n2) {
        int len1 = s1.length(), len2 = s2.length();
        // count1: number of s1 blocks processed
        // count2: number of s2 blocks completed
        int count1 = 0, count2 = 0, index = 0;
        
        // record[index] stores {count1, count2}
        unordered_map<int, pair<int, int>> record;

        while (count1 < n1) {
            count1++;
            for (int i = 0; i < len1; i++) {
                if (s1[i] == s2[index]) {
                    index++;
                    if (index == len2) {
                        count2++;
                        index = 0;
                    }
                }
            }

            // Check if we have encountered this index before (Cycle found)
            if (record.count(index)) {
                auto prev = record[index];
                int prevCount1 = prev.first;
                int prevCount2 = prev.second;

                // Length of the cycle in terms of s1 and s2 blocks
                int cycleLen1 = count1 - prevCount1;
                int cycleLen2 = count2 - prevCount2;

                // How many cycles fit in the remaining n1
                int remainingS1 = (n1 - count1) / cycleLen1;
                count1 += remainingS1 * cycleLen1;
                count2 += remainingS1 * cycleLen2;
            }
            // Record current state
            record[index] = {count1, count2};
        }

        // Result is total s2 blocks / n2
        return count2 / n2;
    }
};
