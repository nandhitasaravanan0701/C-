#include <vector>
#include <numeric>
#include <algorithm>

using namespace std;

class Solution {
public:
    int findMinMoves(vector<int>& machines) {
        int n = machines.size();
        int total = accumulate(machines.begin(), machines.end(), 0);
        
        // If dresses can't be divided equally, return -1
        if (total % n != 0) return -1;
        
        int avg = total / n;
        int maxMoves = 0;
        int currentBalance = 0;
        
        for (int load : machines) {
            int balance = load - avg;
            currentBalance += balance;
            
            // The bottleneck is the maximum of:
            // 1. The net flow needed through this point (abs of currentBalance)
            // 2. The amount a single machine needs to offload (balance)
            maxMoves = max({maxMoves, abs(currentBalance), balance});
        }
        
        return maxMoves;
    }
};
